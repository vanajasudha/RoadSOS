# ── Server ────────────────────────────────────────────────────────────────────
# Port the Express server listens on. Hosting platforms (Railway, Render) set
# this automatically; leave it out locally to default to 5000.
PORT=5000

# Set to "production" on deployed environments.
# Controls: OTP visibility in API responses, error detail in 500 responses,
# route listing on startup, and JWT_SECRET default-value guard.
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string. Required — server will not start without it.
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<name>
MONGO_URI=

# ── Authentication ────────────────────────────────────────────────────────────
# Secret used to sign and verify JWT tokens. Required.
# Must be changed from the default before running NODE_ENV=production.
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# ── SMS Gateway (MSG91) ───────────────────────────────────────────────────────
# Leave blank to run in console-fallback mode (no real SMS sent — safe for dev).
# All three values are required together for live SMS dispatch.
MSG91_AUTH_KEY=
MSG91_SENDER_ID=ROADSS
MSG91_ROUTE=4

# ── CORS ──────────────────────────────────────────────────────────────────────
# Restrict HTTP origin for web clients. Leave unset (or set to *) for
# mobile-only deployments — React Native does not send an Origin header.
# Example for a web dashboard: CORS_ORIGIN=https://dashboard.roadsos.in
CORS_ORIGIN=
