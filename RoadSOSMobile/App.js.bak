import React, {useRef, useEffect} from 'react';
import {Text, View} from 'react-native';
import {NavigationContainer, CommonActions} from '@react-navigation/native';
import {createNativeStackNavigator}  from '@react-navigation/native-stack';
import {createBottomTabNavigator}    from '@react-navigation/bottom-tabs';
import {accelerometer, setUpdateIntervalForType, SensorTypes} from 'react-native-sensors';

import {AuthProvider, useAuth} from './src/context/AuthContext';
import {NetworkProvider}       from './src/context/NetworkContext';

import LoginScreen           from './src/screens/LoginScreen';
import OTPScreen             from './src/screens/OTPScreen';
import HomeScreen            from './src/screens/HomeScreen';
import NearbyServicesScreen  from './src/screens/NearbyServicesScreen';
import EmergencyNumbersScreen from './src/screens/EmergencyNumbersScreen';
import AlertHistoryScreen    from './src/screens/AlertHistoryScreen';
import ProfileScreen         from './src/screens/ProfileScreen';
import CountdownScreen       from './src/screens/CountdownScreen';
import ContactsScreen        from './src/screens/ContactsScreen';
import MedicalQRScreen       from './src/screens/MedicalQRScreen';
import OfflineModeScreen     from './src/screens/OfflineModeScreen';

import {colors} from './src/theme/colors';

const Tab   = createBottomTabNavigator();
const Stack = createNativeStackNavigator();

const CRASH_THRESHOLD = 28;
const COOLDOWN_MS     = 10000;

const TabIcon = ({icon, focused}) => (
  <View style={{
    width: 32, height: 32,
    alignItems: 'center', justifyContent: 'center',
    backgroundColor: focused ? colors.primaryLight : 'transparent',
    borderRadius: 10,
  }}>
    <Text style={{fontSize: 20}}>{icon}</Text>
  </View>
);

const MainTabs = () => (
  <Tab.Navigator
    screenOptions={{
      headerShown: false,
      tabBarStyle: {
        backgroundColor: colors.navBg,
        borderTopWidth: 1,
        borderTopColor: colors.border,
        height: 64,
        paddingBottom: 10,
        paddingTop: 6,
        elevation: 12,
        shadowColor: '#000',
        shadowOffset: {width: 0, height: -2},
        shadowOpacity: 0.08,
        shadowRadius: 8,
      },
      tabBarActiveTintColor:   colors.navActive,
      tabBarInactiveTintColor: colors.textMuted,
      tabBarLabelStyle: {fontSize: 10, fontWeight: '700', marginTop: 2},
    }}>
    <Tab.Screen
      name="Home"
      component={HomeScreen}
      options={{tabBarLabel: 'Home', tabBarIcon: ({focused}) => <TabIcon icon="🏠" focused={focused} />}}
    />
    <Tab.Screen
      name="Nearby"
      component={NearbyServicesScreen}
      options={{tabBarLabel: 'Nearby', tabBarIcon: ({focused}) => <TabIcon icon="📍" focused={focused} />}}
    />
    <Tab.Screen
      name="Numbers"
      component={EmergencyNumbersScreen}
      options={{tabBarLabel: 'Emergency', tabBarIcon: ({focused}) => <TabIcon icon="📞" focused={focused} />}}
    />
    <Tab.Screen
      name="History"
      component={AlertHistoryScreen}
      options={{tabBarLabel: 'History', tabBarIcon: ({focused}) => <TabIcon icon="📋" focused={focused} />}}
    />
    <Tab.Screen
      name="Offline"
      component={OfflineModeScreen}
      options={{tabBarLabel: 'Offline', tabBarIcon: ({focused}) => <TabIcon icon="📶" focused={focused} />}}
    />
    <Tab.Screen
      name="Profile"
      component={ProfileScreen}
      options={{tabBarLabel: 'Profile', tabBarIcon: ({focused}) => <TabIcon icon="👤" focused={focused} />}}
    />
  </Tab.Navigator>
);

const AppNavigator = () => {
  const {isLoggedIn, ready} = useAuth();
  const navigationRef  = useRef(null);
  const lastTriggerRef = useRef(0);
  const prevLoggedIn   = useRef(isLoggedIn);

  useEffect(() => {
    const nav = navigationRef.current;
    if (!nav || !ready) {return;}
    if (prevLoggedIn.current === isLoggedIn) {return;}
    prevLoggedIn.current = isLoggedIn;
    if (isLoggedIn) {
      nav.dispatch(CommonActions.reset({index: 0, routes: [{name: 'MainTabs'}]}));
    } else {
      nav.dispatch(CommonActions.reset({index: 0, routes: [{name: 'Login'}]}));
    }
  }, [isLoggedIn, ready]);

  useEffect(() => {
    try {
      setUpdateIntervalForType(SensorTypes.accelerometer, 100);
      const subscription = accelerometer.subscribe(
        ({x, y, z}) => {
          const magnitude = Math.sqrt(x * x + y * y + z * z);
          const now = Date.now();
          if (magnitude > CRASH_THRESHOLD && now - lastTriggerRef.current > COOLDOWN_MS) {
            lastTriggerRef.current = now;
            const route = navigationRef.current?.getCurrentRoute()?.name;
            if (route !== 'Countdown') {
              navigationRef.current?.navigate('Countdown', {source: 'sensor'});
            }
          }
        },
        err => console.warn('[Accelerometer]', err),
      );
      return () => subscription.unsubscribe();
    } catch (err) {
      console.warn('[Accelerometer setup]', err);
    }
  }, []);

  if (!ready) {
    return (
      <View style={{flex: 1, backgroundColor: colors.background}} />
    );
  }

  return (
    <NavigationContainer ref={navigationRef}>
      <Stack.Navigator
        initialRouteName={isLoggedIn ? 'MainTabs' : 'Login'}
        screenOptions={{headerShown: false}}>
        <Stack.Screen name="Login"     component={LoginScreen} />
        <Stack.Screen name="OTP"       component={OTPScreen} />
        <Stack.Screen name="MainTabs"  component={MainTabs} />
        <Stack.Screen name="Countdown" component={CountdownScreen} />
        <Stack.Screen name="Contacts"  component={ContactsScreen} />
        <Stack.Screen name="MedicalQR" component={MedicalQRScreen} />
      </Stack.Navigator>
    </NavigationContainer>
  );
};

export default function App() {
  return (
    <NetworkProvider>
      <AuthProvider>
        <AppNavigator />
      </AuthProvider>
    </NetworkProvider>
  );
}
